{
    "manifest_version": 3,
    "name": "Port Sloty - Asystent",
    "version": "2.6.2",
    "description": "Twój asystent do zarządzania slotami i monitorowania kontenerów w portach",
    "permissions": ["storage", "webRequest", "notifications", "tabs", "alarms"],
    "host_permissions": [
        "https://ebrama.baltichub.com/*",
        "https://*.supabase.co/*",
        "https://baltichub.com/*",
        "https://ebrama.bct.ictsi.com/*",
        "https://terminal.gct.pl/*",
        "https://api.brevo.com/*"
    ],
    "icons": {
        "16": "128.png",
        "48": "128.png",
        "128": "128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icon-144x144.png",
            "48": "icon-144x144.png",
            "128": "icon-144x144.png"
        }
    },
    "content_scripts": [
        {
            "matches": ["https://*.baltichub.com/*"],
            "js": ["content.js"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["welcome.html"],
            "matches": ["<all_urls>"]
        }
    ]
}
